# Required: Your Anthropic API key (from console.anthropic.com)
# This is separate from your Claude Code subscription — it uses API credits.
ANTHROPIC_API_KEY=sk-ant-...

# Model for orchestrator planning/validation (can also use --model flag)
# Options: claude-sonnet-4-5-20250514, claude-opus-4-5-20250514, claude-haiku-4-5-20251001, etc.
# MODEL=claude-4-sonnet-20250514

# Optional overrides
# PORT=3100
# WORKSPACE_PATH=./workspace
# LOG_LEVEL=info
